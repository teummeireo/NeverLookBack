<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="com.nlb.mapper.NlbUserMapper">


    <select id = "selectUsers" resultType="NlbUserVO">
        select *
        from nlbuser
    </select>

    <update id="updateUserIsActive">
        update nlbuser
        set is_active = #{isActive}
        where user_id = #{userId}
    </update>

    <select id="selectUserByUserId"  resultType="NlbUserVO">
        select *
        from nlbuser
        where user_id = #{userId}
    </select>

    <update id="updateUserDeactivate">
        update nlbuser
        set is_active = false
        where user_id = #{userId}
    </update>

    <select id ="selectNicknameByUserId" resultType="String">
        select nickname
        from nlbuser
        where user_id = #{userId}
    </select>

    <select id ="selectPasswordByUserId" resultType="String">
        select password
        from nlbuser
        where user_id = #{userId}
    </select>

    <update id="updateUser">
        UPDATE nlbuser
        <set>
            <if test="uvo.password != null">
                password = #{uvo.password},
            </if>
            <if test="uvo.nickname != null">
                nickname = #{uvo.nickname},
            </if>
        </set>
        WHERE user_id = #{uvo.userId}
    </update>
</mapper>